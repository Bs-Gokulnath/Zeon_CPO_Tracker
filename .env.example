# ══════════════════════════════════════════════════════════════════════════════
# Statiq Scraper — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/statiq_db
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/statiq_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Scraper: concurrency & timing ─────────────────────────────────────────────
# Maximum simultaneous HTTP connections to statiq.in detail pages
SCRAPER_CONCURRENCY=50

# Requests per minute sent to statiq.in (detail pages)
SCRAPER_RATE_LIMIT_PER_MINUTE=80

# Requests per minute sent to backend.statiq.co.in (API)
SCRAPER_API_RATE_LIMIT_PER_MINUTE=10

# Seconds before an HTTP request is considered timed out
SCRAPER_REQUEST_TIMEOUT=30

# Maximum retry attempts per failed request
SCRAPER_MAX_RETRIES=5

# ── Scraper: freshness / incremental ──────────────────────────────────────────
# Hours before a successfully scraped station is considered stale (re-scraped)
SCRAPER_STATION_FRESHNESS_TTL_HOURS=24

# Days before the city list cache expires
SCRAPER_CITY_CACHE_TTL_DAYS=7

# ── Statiq API endpoints (do not change unless the site changes) ──────────────
STATIQ_BASE_URL=https://www.statiq.in
STATIQ_MARKERS_URL=https://backend.statiq.co.in/station/v1/markers
STATIQ_CITIES_URL=https://backend.statiq.co.in/station/v1/city_data

# ── India bounding box for markers API (covers all of India) ─────────────────
# Format: "lon_west,lat_north,lon_east,lat_south"
STATIQ_INDIA_BBOX=68.0,37.0,97.5,8.0

# ── Output paths ──────────────────────────────────────────────────────────────
RAW_DATA_DIR=data/raw
FAILED_DATA_DIR=data/failed
LOG_DIR=logs
CHECKPOINT_FILE=logs/checkpoint.json

# ── Logging ───────────────────────────────────────────────────────────────────
# One of: TRACE, DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ── Proxy (disabled by default — only enable if IP is rate-limited) ───────────
PROXY_ENABLED=false
# PROXY_URL=http://user:pass@proxy-host:port
# PROXY_ROTATION_ENABLED=false

# ── Playwright fallback ───────────────────────────────────────────────────────
# Activate browser fallback when RSC parser returns empty data
PLAYWRIGHT_FALLBACK_ENABLED=true
PLAYWRIGHT_HEADLESS=true

# ── Storage ───────────────────────────────────────────────────────────────────
# Whether to write raw RSC payload files to disk at all
STORE_RAW_RSC=true
# If true, raw files are gzip-compressed (.txt.gz) — saves ~70% disk space
COMPRESS_RAW_RSC=true

# ── Batch processing ──────────────────────────────────────────────────────────
# Number of stations scraped per batch before writing a checkpoint
SCRAPER_BATCH_SIZE=250
# Random inter-batch sleep range in seconds (reduces server-side rate-limiting)
SCRAPER_BATCH_JITTER_MIN=2.0
SCRAPER_BATCH_JITTER_MAX=5.0

# ── Output paths (pipeline) ───────────────────────────────────────────────────
# Directory where per-run checkpoint JSON files are stored
CHECKPOINTS_DIR=data/checkpoints
# Directory where final normalised tables (JSON + CSV) are written
FINAL_DATA_DIR=data/final
# Directory where quality-metric reports are written
REPORTS_DIR=reports
